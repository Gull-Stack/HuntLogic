{
  "name": "huntlogic",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:setup": "bash scripts/db-setup.sh",
    "db:migrate": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/lib/db/seed.ts",
    "db:validate": "tsx src/lib/db/validate.ts",
    "db:studio": "drizzle-kit studio",
    "db:reset": "docker compose down -v postgres && bash scripts/db-setup.sh",
    "ingestion:start": "tsx src/services/ingestion/start.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@auth/core": "^0.37.0",
    "@auth/drizzle-adapter": "^1.7.0",
    "@google/genai": "^1.45.0",
    "@radix-ui/react-dialog": "^1.1.5",
    "@radix-ui/react-dropdown-menu": "^2.1.5",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.5",
    "@tanstack/react-query": "^5.65.0",
    "@types/bcryptjs": "^2.4.6",
    "ai": "^4.1.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.34.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.38.0",
    "ioredis": "^5.4.0",
    "lucide-react": "^0.474.0",
    "maplibre-gl": "^4.7.0",
    "meilisearch": "^0.46.0",
    "minio": "^8.0.0",
    "next": "^15.2.0",
    "next-auth": "^5.0.0-beta.25",
    "openai": "^6.27.0",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-map-gl": "^7.1.8",
    "recharts": "^2.15.0",
    "resend": "^4.1.0",
    "sharp": "^0.33.0",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
