# =============================================================================
# HuntLogic Concierge — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="HuntLogic Concierge"
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database — PostgreSQL 16 (with pgvector + PostGIS)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://huntlogic:huntlogic_dev@localhost:5432/huntlogic
DATABASE_POOL_SIZE=10

# -----------------------------------------------------------------------------
# Redis — Session cache, rate limiting, queue
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Authentication — NextAuth.js
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers (optional — enable as needed)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# AI — Anthropic Claude
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
# Model to use for general queries
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Model for complex analysis / planning
ANTHROPIC_MODEL_ADVANCED=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# Search — Meilisearch
# -----------------------------------------------------------------------------
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=huntlogic_meili_dev_key

# -----------------------------------------------------------------------------
# Object Storage — MinIO (S3-compatible)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=huntlogic_minio
MINIO_SECRET_KEY=huntlogic_minio_secret
MINIO_BUCKET=huntlogic-data
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# Map — MapLibre / MapTiler
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MAPTILER_KEY=
NEXT_PUBLIC_MAP_STYLE_URL=

# -----------------------------------------------------------------------------
# Forecasting API — Python FastAPI service
# -----------------------------------------------------------------------------
FORECASTING_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Email — Transactional email provider
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="HuntLogic <noreply@huntlogic.com>"

# -----------------------------------------------------------------------------
# Push Notifications
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@huntlogic.com

# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_AI_CHAT=true
ENABLE_FORECASTING=true
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_MAP_FEATURES=true
