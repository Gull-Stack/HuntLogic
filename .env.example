# =============================================================================
# HuntLogic Concierge — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="HuntLogic Concierge"
NEXT_PUBLIC_BRAND_NAME="HuntLogic"
NEXT_PUBLIC_AI_ASSISTANT_NAME="Teddy"
SUPPORT_EMAIL=support@huntlogic.com
TELEGRAM_BOT_HANDLE=@TeddyLogicBot
NEXT_PUBLIC_TELEGRAM_BOT_URL=https://t.me/TeddyLogicBot
BRAND_PRIMARY_COLOR=#1A3C2A
BRAND_ACCENT_COLOR=#C4651A
BRAND_ACCENT_SECONDARY=#D4A03C
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database — PostgreSQL 16 (with pgvector + PostGIS)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://huntlogic:huntlogic_dev@localhost:5432/huntlogic
DATABASE_POOL_SIZE=10

# -----------------------------------------------------------------------------
# Redis — Session cache, rate limiting, queue
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Auth.js / NextAuth v5
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Apple OAuth
# -----------------------------------------------------------------------------
APPLE_ID=
APPLE_TEAM_ID=
APPLE_PRIVATE_KEY=
APPLE_KEY_ID=

# -----------------------------------------------------------------------------
# Email (Resend — magic link authentication)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="HuntLogic <noreply@huntlogic.com>"

# -----------------------------------------------------------------------------
# AI — Anthropic Claude
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
# Model to use for general queries
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Model for complex analysis / planning
ANTHROPIC_MODEL_ADVANCED=claude-sonnet-4-20250514
# Embedding model (Gemini)
EMBEDDING_MODEL=gemini-embedding-001

# -----------------------------------------------------------------------------
# Search — Meilisearch
# -----------------------------------------------------------------------------
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=huntlogic_meili_dev_key

# -----------------------------------------------------------------------------
# Object Storage — MinIO (S3-compatible)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=huntlogic_minio
MINIO_SECRET_KEY=huntlogic_minio_secret
MINIO_BUCKET=huntlogic-data
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# Map — MapLibre / MapTiler
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MAPTILER_KEY=
NEXT_PUBLIC_MAP_STYLE_URL=

# -----------------------------------------------------------------------------
# Forecasting API — Python FastAPI service
# -----------------------------------------------------------------------------
FORECASTING_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Push Notifications
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@huntlogic.com

# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# -----------------------------------------------------------------------------
# Stripe — Payment Processing
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SIMULATION=5
RATE_LIMIT_CREDENTIALS=5

# -----------------------------------------------------------------------------
# Cache TTLs & Session
# -----------------------------------------------------------------------------
CACHE_PROMPT_TTL_MS=300000
CACHE_CONFIG_TTL_MS=300000
SESSION_MAX_AGE=2592000

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_AI_CHAT=true
ENABLE_FORECASTING=true
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_MAP_FEATURES=true

# -----------------------------------------------------------------------------
# Deployment — Vercel
# -----------------------------------------------------------------------------
VERCEL_URL=  # Auto-set by Vercel
CRON_SECRET=  # Verify cron job requests — generate with: openssl rand -base64 32
